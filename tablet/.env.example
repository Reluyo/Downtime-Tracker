# Supabase connection for the tablet app.
# Copy this file to `.env` and fill in your project values.
# Use the PUBLISHABLE (anon) key only — tablets have no admin login.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# Which line this tablet is assigned to (PoC: one tablet = the whole line).
LINE_SHORT_NAME=PRSA 2
