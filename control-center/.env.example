# Supabase connection for the control center.
# Copy this file to `.env` and fill in your project values.
# Find these in Supabase: Settings -> API. Use the PUBLISHABLE (anon) key only —
# never the secret/service key in a client app.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx
